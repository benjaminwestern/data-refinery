{
  "path": "./test_data",
  "key": "id",
  "workers": 4,
  "logPath": "logs",
  "checkKey": true,
  "checkRow": true,
  "showFolderBreakdown": true,
  "enableTxtOutput": true,
  "enableJsonOutput": true,
  "advanced": {
    "searchTargets": [
      {
        "name": "customer_match",
        "type": "direct",
        "path": "customer_id",
        "targetValues": ["cust-123"],
        "caseSensitive": false
      },
      {
        "name": "product_match",
        "type": "nested_object",
        "path": "product.name",
        "targetValues": ["widget"],
        "caseSensitive": false
      },
      {
        "name": "line_item_match",
        "type": "nested_array",
        "path": "line_items[*].item_id",
        "targetValues": ["li-001"],
        "caseSensitive": false
      }
    ],
    "hashingStrategy": {
      "mode": "selective",
      "includeKeys": ["id", "customer_id", "product.name"],
      "algorithm": "fnv",
      "normalize": true
    },
    "schemaDiscovery": {
      "enabled": true,
      "samplePercent": 0.5,
      "maxDepth": 5,
      "maxSamples": 1000,
      "outputFormats": ["json"],
      "groupByFolder": true
    },
    "deletionRules": [
      {
        "searchTarget": "customer_match",
        "action": "mark_for_deletion",
        "outputPath": "logs/review/marked-customers.jsonl"
      },
      {
        "searchTarget": "line_item_match",
        "action": "delete_matches",
        "outputPath": "logs/derived/line-items-pruned.jsonl"
      }
    ]
  }
}
