{
  "path": "/data/orders",
  "key": "id",
  "workers": 8,
  "logPath": "logs",
  "checkKey": true,
  "checkRow": true,
  "showFolderBreakdown": true,
  "enableTxtOutput": true,
  "enableJsonOutput": true,
  "purgeIds": false,
  "purgeRows": false,
  "advanced": {
    "searchTargets": [
      {
        "name": "customer_ids",
        "type": "direct",
        "path": "customer_id",
        "targetValues": ["cust-123", "cust-456", "cust-789"],
        "caseSensitive": false
      },
      {
        "name": "line_item_ids",
        "type": "nested_array",
        "path": "line_items[*].item_id",
        "targetValues": ["li-001", "li-002", "li-003"],
        "caseSensitive": false
      },
      {
        "name": "product_names",
        "type": "nested_object",
        "path": "product.name",
        "targetValues": ["widget", "bundle"],
        "caseSensitive": false
      }
    ],
    "hashingStrategy": {
      "mode": "exclude_keys",
      "excludeKeys": ["updated_at", "processed_at", "exported_at"],
      "algorithm": "fnv",
      "normalize": true
    },
    "deletionRules": [
      {
        "searchTarget": "customer_ids",
        "action": "delete_row",
        "outputPath": "derived/deleted-customers.jsonl"
      },
      {
        "searchTarget": "line_item_ids",
        "action": "delete_matches",
        "outputPath": "derived/cleaned-line-items.jsonl"
      },
      {
        "searchTarget": "product_names",
        "action": "mark_for_deletion",
        "outputPath": "review/product-name-matches.jsonl"
      }
    ],
    "schemaDiscovery": {
      "enabled": true,
      "samplePercent": 0.1,
      "maxDepth": 5,
      "maxSamples": 50000,
      "outputFormats": ["json", "csv", "yaml"],
      "groupByFolder": true
    },
    "backup": {
      "enabled": true,
      "backupDir": "backups",
      "retentionDays": 30,
      "compression": false
    },
    "output": {
      "formats": ["txt", "json"],
      "destination": "output",
      "compression": false
    }
  }
}
