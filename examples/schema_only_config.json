{
  "path": "/data/orders",
  "key": "id",
  "workers": 4,
  "logPath": "logs",
  "checkKey": false,
  "checkRow": false,
  "showFolderBreakdown": false,
  "enableTxtOutput": false,
  "enableJsonOutput": true,
  "purgeIds": false,
  "purgeRows": false,
  "advanced": {
    "searchTargets": [],
    "hashingStrategy": {
      "mode": "full_row",
      "algorithm": "fnv",
      "normalize": true
    },
    "deletionRules": [],
    "schemaDiscovery": {
      "enabled": true,
      "samplePercent": 0.05,
      "maxDepth": 10,
      "maxSamples": 100000,
      "outputFormats": ["json", "csv", "yaml"],
      "groupByFolder": true
    },
    "backup": {
      "enabled": false,
      "backupDir": "backups",
      "retentionDays": 30,
      "compression": false
    },
    "output": {
      "formats": ["json", "csv"],
      "destination": "output",
      "compression": false
    }
  }
}
