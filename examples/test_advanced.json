{
  "path": "./test_data",
  "key": "id",
  "workers": 4,
  "logPath": "logs",
  "checkKey": true,
  "checkRow": true,
  "showFolderBreakdown": true,
  "enableTxtOutput": true,
  "enableJsonOutput": true,
  "purgeIds": false,
  "purgeRows": false,
  "advanced": {
    "searchTargets": [
      {
        "name": "customer_match",
        "type": "direct",
        "path": "customer_id",
        "targetValues": ["cust-123"],
        "caseSensitive": false
      }
    ],
    "hashingStrategy": {
      "mode": "selective",
      "includeKeys": ["id", "customer_id"],
      "algorithm": "fnv",
      "normalize": true
    },
    "deletionRules": [],
    "schemaDiscovery": {
      "enabled": true,
      "samplePercent": 0.1,
      "maxDepth": 3,
      "maxSamples": 100,
      "outputFormats": ["json"],
      "groupByFolder": false
    },
    "backup": {
      "enabled": false,
      "backupDir": "backups",
      "retentionDays": 7,
      "compression": false
    },
    "output": {
      "formats": ["json"],
      "destination": "output",
      "compression": false
    }
  }
}
