{
  "path": "./test_data",
  "key": "id",
  "workers": 4,
  "logPath": "logs",
  "checkKey": true,
  "checkRow": true,
  "showFolderBreakdown": true,
  "enableTxtOutput": true,
  "enableJsonOutput": true,
  "purgeIds": false,
  "purgeRows": false,
  "advanced": {
    "searchTargets": [
      {
        "name": "customer_match",
        "type": "direct",
        "path": "customer_id",
        "targetValues": ["cust-123"],
        "caseSensitive": false
      },
      {
        "name": "line_item_ids",
        "type": "nested_array",
        "path": "line_items[*].item_id",
        "targetValues": ["li-001"],
        "caseSensitive": false
      }
    ],
    "hashingStrategy": {
      "mode": "exclude_keys",
      "excludeKeys": ["metadata.created"],
      "algorithm": "fnv",
      "normalize": true
    },
    "deletionRules": [
      {
        "searchTarget": "customer_match",
        "action": "delete_row",
        "outputPath": "logs/derived/deleted-customers.jsonl"
      },
      {
        "searchTarget": "line_item_ids",
        "action": "delete_matches",
        "outputPath": "logs/derived/cleaned-line-items.jsonl"
      }
    ],
    "schemaDiscovery": {
      "enabled": true,
      "samplePercent": 0.1,
      "maxDepth": 5,
      "maxSamples": 500,
      "outputFormats": ["json", "csv"],
      "groupByFolder": true
    },
    "backup": {
      "enabled": false,
      "backupDir": "backups",
      "retentionDays": 7,
      "compression": false
    },
    "output": {
      "formats": ["txt", "json"],
      "destination": "output",
      "compression": false
    }
  }
}
