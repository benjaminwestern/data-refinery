direction: right

classes: {
  stage: {
    style.fill: "#FBF7F0"
    style.stroke: "#2A2A33"
    style.stroke-width: 1
  }
  action: {
    style.fill: "#66CAD8"
    style.stroke: "#2A2A33"
    style.stroke-width: 1
  }
  decision: {
    shape: diamond
    style.fill: "#F9EB00"
    style.stroke: "#2A2A33"
    style.stroke-width: 1
  }
  output: {
    style.fill: "#C8643B"
    style.stroke: "#2A2A33"
    style.stroke-width: 1
    style.font-color: "#FFF9F1"
  }
}

Input: {class: stage; label: "Discover source files"}
Match: {class: action; label: "Match mapping rule"}
Normalise: {class: action; label: "Normalise to standard schema"}
Format: {class: decision; label: "Output format"}
CSVCheck: {class: decision; label: "Nested fields present?"}
CSVOut: {class: output; label: "Write csv"}
JSONOut: {class: output; label: "Write json / ndjson / jsonl"}
Summary: {class: output; label: "Write ingest summary and log"}
Error: {class: output; label: "Fail and advise JSON-family output"}

Input -> Match
Match -> Normalise
Normalise -> Format
Format -> CSVCheck: "csv"
CSVCheck -> CSVOut: "no"
CSVCheck -> Error: "yes"
Format -> JSONOut: "json / ndjson / jsonl"
CSVOut -> Summary
JSONOut -> Summary
